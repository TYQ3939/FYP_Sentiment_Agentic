# ============================================================
# Streamlit secrets — paste this into the Streamlit Community
# Cloud dashboard under App Settings → Secrets.
#
# DO NOT commit the real secrets.toml to GitHub.
# This .example file is safe to commit.
# ============================================================

# URL of your Google Cloud VM backend
API_BASE_URL = "http://YOUR_VM_EXTERNAL_IP:8000"

# LLM & Search API keys (same values as your .env file)
GROQ_API_KEY        = "your_groq_api_key_here"
TAVILY_API_KEY      = "your_tavily_api_key_here"
SERPER_API_KEY      = "your_serper_api_key_here"
GOOGLE_CSE_ID       = "your_google_cse_id_here"
GOOGLE_API_KEY      = "your_google_api_key_here"
